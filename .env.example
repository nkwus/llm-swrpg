# Copy this file to .env and fill in your values.
# cp .env.example .env

# Required — obtain from https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# Optional — Groq model to use for generating answers
# See available models at https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile

# Optional — ChromaDB storage path
# On Railway with a mounted Volume at /data, set this to /data/chroma
CHROMA_DIR=chroma

# Optional — ChromaDB collection name
COLLECTION_NAME=star_wars_rpg

# Optional — Sentence-transformers embedding model
# WARNING: changing this after ingestion requires deleting CHROMA_DIR and re-processing PDFs
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional — number of text chunks to retrieve per question (higher = more context, slower)
RETRIEVAL_K=15

# Optional — PDF upload directory
# On Railway with a mounted Volume at /data, set this to /data/uploads
# DATA_DIR=data
